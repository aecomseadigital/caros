# Copy to .env and fill in. Never commit .env.

# Caros CLI binary (build with: cargo build --release  → target/release/caros[.exe])
CAROS_BIN=../../target/release/caros

# Web target URLs
OSCAR_URL=https://oscar.aecom.global/home
COPILOT_URL=https://m365.cloud.microsoft/chat

# Judge model — MUST be a different family from the targets (targets are GPT/AOAI).
# A Claude model reduces self-preference bias.
ANTHROPIC_API_KEY=

# Copilot automation gate. Leave BLANK until you have manager/IT sign-off AND have
# created the file .auth/copilot.consent. Then set to 1.
ALLOW_COPILOT=

# Optional: override Playwright headed/headless (default headed for auth realism)
HEADLESS=0
