# ---- Server ----
PORT=80

# ---- Azure OpenAI (account: caros, westus) ----
AOAI_ENDPOINT=https://caros.openai.azure.com/
AOAI_API_VERSION=2025-04-01-preview
# managed_identity (recommended) | api_key
AOAI_AUTH_MODE=managed_identity
# only used when AOAI_AUTH_MODE=api_key
AZURE_OPENAI_API_KEY=
# scope for the managed-identity token
AOAI_MI_SCOPE=https://cognitiveservices.azure.com/.default
# deployment names on the caros account
AOAI_DEPLOYMENT_MINI=gpt-5.4-mini
AOAI_DEPLOYMENT_NANO=gpt-5.4-nano

# ---- Classifier ----
# when heuristics are uncertain, ask gpt-5.4-nano to classify
CLASSIFIER_NANO_FALLBACK=true
# estimated-token count above which a request routes to mini
CLASSIFIER_LARGE_TOKENS=6000

# ---- Caller auth (set by APIM in front of the gateway) ----
# shared secret APIM injects. The gateway has a PUBLIC ingress: if this is empty
# the gateway REJECTS all requests (fail closed) unless ALLOW_INSECURE_NO_SECRET=true.
GATEWAY_SHARED_SECRET=
# local dev only — allow running with no shared secret. NEVER set in production.
ALLOW_INSECURE_NO_SECRET=false
GATEWAY_SECRET_HEADER=x-gateway-secret
USER_OID_HEADER=x-user-oid
USER_UPN_HEADER=x-user-upn

# ---- Telemetry ----
APPLICATIONINSIGHTS_CONNECTION_STRING=
